---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';

// ── Generazione percorsi statici ─────────────────────────────────────────────
export async function getStaticPaths() {
  const servizi = await getCollection('servizi');
  return servizi.map(s => ({ params: { id: s.id } }));
}

// ── Dati del servizio corrente ────────────────────────────────────────────────
const { id } = Astro.params;
const servizio = await getEntry('servizi', id);

// Redirect se non trovato (non dovrebbe mai accadere con getStaticPaths)
if (!servizio) {
  return Astro.redirect('/servizi');
}

// ── Utility slug → stringa leggibile ─────────────────────────────────────────
function slugToString(titolo: string | { slug: string }): string {
  return typeof titolo === 'string' ? titolo : titolo.slug;
}

const titoloStr = slugToString(servizio.data.titolo).replace(/-/g, ' ');

// ── Servizi correlati (tutti tranne il corrente, max 3) ───────────────────────
const tuttiServizi = await getCollection('servizi');
const correlati = tuttiServizi
  .filter(s => s.id !== servizio.id)
  .sort((a, b) => (a.data.ordine ?? 99) - (b.data.ordine ?? 99))
  .slice(0, 3);

// ── Risoluzione immagine principale ──────────────────────────────────────────
const immagine    = servizio.data.immagine;
const imgCorrelati = correlati.map(s => s.data.immagine);

// ── Icone ─────────────────────────────────────────────────────────────────────
const icone: Record<string, string> = {
  leaf: `<path d="M17 8C8 10 5.9 16.17 3.82 19.34L5.71 21l1-1c.28.27.49.55.83.55.35 0 .65-.3.86-.57A8.48 8.48 0 0010 14.5a11.1 11.1 0 013.47 5.85l1.88-1.88A14 14 0 0012.85 11c1.07.49 2.63 1.38 4.42 3.41l1.46-1.46C17 11.49 17 8 17 8z"/>`,
  tree: `<path d="M17 8C8 10 5.9 16.17 3.82 19.34L5.71 21l1-1c.28.27.49.55.83.55.35 0 .65-.3.86-.57A8.48 8.48 0 0010 14.5a11.1 11.1 0 013.47 5.85l1.88-1.88A14 14 0 0012.85 11c1.07.49 2.63 1.38 4.42 3.41l1.46-1.46C17 11.49 17 8 17 8z"/>`,
  '3d': `<path d="M21 16.5c0 .38-.21.71-.53.88l-7.9 4.44c-.16.12-.36.18-.57.18-.21 0-.41-.06-.57-.18l-7.9-4.44A1 1 0 013 16.5v-9c0-.38.21-.71.53-.88l7.9-4.44c.16-.12.36-.18.57-.18.21 0 .41.06.57.18l7.9 4.44c.32.17.53.5.53.88v9zM12 4.15L6.04 7.5 12 10.85l5.96-3.35L12 4.15zM5 15.91l6 3.38v-6.71L5 9.21v6.7zm8 3.38l6-3.38V9.21l-6 3.37v6.71z"/>`,
};
---

<Layout
  title={`${titoloStr} | Roverati Giardini`}
  description={servizio.data.descrizioneBreve}
>

  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section class="relative bg-green-950 pt-36 pb-0 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full bg-green-800/15 blur-3xl translate-x-1/3 -translate-y-1/4"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-6">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 mb-10 text-xs text-white/30 font-medium tracking-wide" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white/60 transition-colors">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/servizi" class="hover:text-white/60 transition-colors">Servizi</a>
        <span aria-hidden="true">/</span>
        <span class="text-green-400">{titoloStr}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-end pb-16">
        <!-- Testo -->
        <div>
          <div class="inline-flex items-center gap-2.5 mb-8 px-4 py-2 rounded-full border border-green-500/30 bg-green-500/10">
            <div class="w-8 h-8 rounded-xl bg-green-500/20 text-green-400 flex items-center justify-center flex-shrink-0">
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4" aria-hidden="true">
                <Fragment set:html={icone[servizio.data.icona ?? 'leaf'] ?? icone['leaf']} />
              </svg>
            </div>
            <span class="text-[10px] font-bold tracking-[0.28em] uppercase text-green-400">Servizio</span>
          </div>
          <h1 class="font-display text-5xl md:text-7xl text-white leading-[0.9] mb-8 capitalize">
            {titoloStr.split(' ').map((word, i) =>
              i === 0
                ? <span>{word}<br/></span>
                : <em class={i % 2 === 0 ? 'text-white font-light' : 'text-green-400 font-light'}>{word} </em>
            )}
          </h1>
          <p class="text-white/55 text-lg font-light leading-relaxed max-w-md mb-10">
            {servizio.data.descrizioneBreve}
          </p>

          <!-- Tags -->
          {servizio.data.tags && servizio.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-10">
              {servizio.data.tags.map(tag => (
                <span class="text-[10px] font-bold tracking-wide uppercase bg-green-500/15 border border-green-500/25 text-green-400 px-3 py-1.5 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
          )}

          <div class="flex flex-wrap gap-3">
            <a href="/contatti" class="inline-flex items-center gap-3 bg-green-500 hover:bg-green-400 text-white px-8 py-4 rounded-full font-semibold text-sm tracking-wide uppercase transition-all duration-300 hover:shadow-xl hover:shadow-green-500/40 hover:-translate-y-0.5 group">
              Richiedi Preventivo
              <span class="w-5 h-5 rounded-full bg-white/20 flex items-center justify-center group-hover:bg-white/30 transition-colors" aria-hidden="true">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </span>
            </a>
            <a href="/servizi" class="inline-flex items-center gap-2 text-white/60 hover:text-white px-6 py-4 rounded-full text-sm font-medium transition-colors border border-white/10 hover:border-white/30">
              ← Tutti i servizi
            </a>
          </div>
        </div>

        <!-- Immagine (se disponibile) -->
        <div class="hidden lg:block">
          {immagine ? (
            <div class="relative aspect-[4/3] rounded-3xl overflow-hidden border border-green-800/50">
              <Image
                src={immagine}
                alt={titoloStr}
                class="w-full h-full object-cover"
                widths={[600, 1000]}
                sizes="50vw"
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-green-950/40 to-transparent"></div>
            </div>
          ) : (
            <!-- Placeholder grafico quando l'immagine non è ancora caricata -->
            <div class="relative aspect-[4/3] rounded-3xl bg-green-900/30 border border-green-800/50 flex items-center justify-center overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-br from-green-800/30 to-green-600/10"></div>
              <div class="relative z-10 w-24 h-24 rounded-full bg-green-500/20 border-2 border-green-400/30 flex items-center justify-center">
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-10 h-10 text-green-400/60" aria-hidden="true">
                  <Fragment set:html={icone[servizio.data.icona ?? 'leaf'] ?? icone['leaf']} />
                </svg>
              </div>
              <p class="absolute bottom-6 left-0 right-0 text-center text-green-600/40 text-xs">
                Aggiungi l'immagine da Keystatic → Servizi
              </p>
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Onda di transizione -->
    <div class="relative h-16 overflow-hidden" aria-hidden="true">
      <svg viewBox="0 0 1440 64" fill="none" class="absolute bottom-0 w-full" preserveAspectRatio="none">
        <path d="M0 64 C360 0 1080 0 1440 64 L1440 64 L0 64 Z" fill="var(--color-cloud)"/>
      </svg>
    </div>
  </section>


  <!-- ═══════════════════ CONTENUTO ═══════════════════ -->
  <section class="py-20 px-6 bg-cloud">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">

        <!-- Contenuto principale -->
        <div class="lg:col-span-8 reveal">
          <div class="bg-white rounded-3xl border border-green-100 p-8 md:p-12">
            <div class="flex items-center gap-3 mb-8">
              <span class="w-8 h-px bg-green-500"></span>
              <span class="text-[10px] font-bold tracking-[0.3em] uppercase text-green-500">Il Servizio</span>
            </div>
            <p class="text-green-800/70 text-base leading-relaxed font-light">
              {servizio.data.descrizioneBreve}
            </p>

            {/* Blocco aggiuntivo di garanzie */}
            <div class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-4">
              {[
                { icon: '✓', label: 'Sopralluogo gratuito' },
                { icon: '⏱', label: 'Preventivo in 48 ore' },
                { icon: '★', label: 'Qualità ISO 9001' },
              ].map(item => (
                <div class="flex items-center gap-3 bg-green-50 rounded-2xl px-4 py-3.5 border border-green-100">
                  <span class="text-green-500 font-bold text-base flex-shrink-0">{item.icon}</span>
                  <span class="text-xs font-semibold text-green-800 tracking-wide">{item.label}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:col-span-4 reveal flex flex-col gap-5" style="transition-delay: 100ms">

          <!-- CTA card -->
          <div class="bg-green-800 rounded-3xl p-7 relative overflow-hidden">
            <div class="absolute -bottom-10 -right-10 w-36 h-36 rounded-full bg-green-600/20 blur-2xl pointer-events-none"></div>
            <div class="relative">
              <h3 class="font-display text-xl text-white mb-3">Interessato a questo servizio?</h3>
              <p class="text-white/45 text-xs leading-relaxed mb-6 font-light">
                Sopralluogo gratuito e preventivo personalizzato entro 48 ore.
              </p>
              <a href="/contatti" class="flex items-center justify-between w-full bg-green-500 hover:bg-green-400 text-white px-5 py-3.5 rounded-xl font-semibold text-sm transition-all duration-200 group">
                Richiedi Preventivo
                <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- ISO badge -->
          <div class="flex items-center gap-4 bg-green-900 rounded-2xl px-5 py-4">
            <div class="w-11 h-11 rounded-xl bg-green-500/20 border border-green-400/20 flex items-center justify-center text-[9px] font-bold text-green-400 leading-tight text-center flex-shrink-0">
              ISO<br/>9001
            </div>
            <div>
              <div class="text-white text-xs font-semibold">Qualità Certificata ISO 9001:2015</div>
              <div class="text-white/40 text-[10px] mt-0.5">Standard elevati su ogni intervento</div>
            </div>
          </div>

          <!-- Tags -->
          {servizio.data.tags && servizio.data.tags.length > 0 && (
            <div class="bg-white rounded-2xl border border-green-100 p-5">
              <p class="text-[10px] font-bold tracking-[0.2em] uppercase text-green-400 mb-3">Specializzazioni</p>
              <div class="flex flex-wrap gap-2">
                {servizio.data.tags.map(tag => (
                  <span class="text-[10px] font-bold tracking-wide uppercase bg-green-50 text-green-700 border border-green-100 px-3 py-1.5 rounded-full">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          )}

        </aside>
      </div>
    </div>
  </section>


  <!-- ═══════════════════ SERVIZI CORRELATI ═══════════════════ -->
  {correlati.length > 0 && (
    <section class="py-20 px-6 bg-green-950">
      <div class="max-w-7xl mx-auto">
        <div class="reveal mb-10">
          <div class="flex items-center gap-3 mb-4">
            <span class="w-8 h-px bg-green-500"></span>
            <span class="text-[10px] font-bold tracking-[0.3em] uppercase text-green-500">Altri Servizi</span>
          </div>
          <h2 class="font-display text-3xl text-white">Potrebbe interessarti anche</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {correlati.map((s, i) => {
            const img = imgCorrelati[i];
            const label = slugToString(s.data.titolo).replace(/-/g, ' ');
            return (
              <a
                href={`/servizi/${s.id}`}
                class="reveal group relative bg-green-900/40 border border-green-800/50 hover:border-green-500/50 rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1"
                style={`transition-delay: ${i * 80}ms`}
              >
                {img ? (
                  <div class="relative aspect-[16/9] overflow-hidden">
                    <Image
                      src={img}
                      alt={label}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 opacity-60 group-hover:opacity-80"
                      widths={[400]}
                      sizes="33vw"
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div class="aspect-[16/9] bg-green-900/60 flex items-center justify-center">
                    <svg viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 text-green-600/50" aria-hidden="true">
                      <Fragment set:html={icone[s.data.icona ?? 'leaf'] ?? icone['leaf']} />
                    </svg>
                  </div>
                )}
                <div class="p-5">
                  <h3 class="text-white font-semibold text-sm capitalize mb-1">{label}</h3>
                  <p class="text-white/40 text-xs leading-relaxed line-clamp-2">{s.data.descrizioneBreve}</p>
                  <span class="inline-flex items-center gap-1.5 mt-4 text-[10px] font-bold tracking-wider uppercase text-green-400 group-hover:text-green-300 transition-colors">
                    Scopri
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

</Layout>
