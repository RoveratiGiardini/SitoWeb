---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import BeforeAfterSlider from '../components/BeforeAfterSlider.astro';

import { getCollection, getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

// Recupero dati CMS
const [tutteTrasformazioni, tuttiServizi, impostazioniHome] = await Promise.all([
  getCollection('trasformazioni'),
  getCollection('servizi'),
  getEntry('impostazioni', 'home') // Recupera il singleton
]);

const slideHome = tutteTrasformazioni[0];
const serviziEvidenza = tuttiServizi
  .filter((s: CollectionEntry<'servizi'>) => s.data.inEvidenza)
  .slice(0, 3);

// L'immagine Hero è già risolta nativamente da Astro grazie a config.ts
const resolvedHeroImage = impostazioniHome?.data.heroImage;

const iconeSVG: Record<string, string> = {
  tree: '<path d="M17 8C8 10 5.9 16.17 3.82 19.34L5.71 21l1-1c.28.27.49.55.83.55.35 0 .65-.3.86-.57A8.48 8.48 0 0010 14.5a11.1 11.1 0 013.47 5.85l1.88-1.88A14 14 0 0012.85 11c1.07.49 2.63 1.38 4.42 3.41l1.46-1.46C17 11.49 17 8 17 8z"/>',
  '3d': '<path d="M21 16.5c0 .38-.21.71-.53.88l-7.9 4.44c-.16.12-.36.18-.57.18-.21 0-.41-.06-.57-.18l-7.9-4.44A1 1 0 013 16.5v-9c0-.38.21-.71.53-.88l7.9-4.44c.16-.12.36-.18.57-.18.21 0 .41.06.57.18l7.9 4.44c.32.17.53.5.53.88v9zM12 4.15L6.04 7.5 12 10.85l5.96-3.35L12 4.15zM5 15.91l6 3.38v-6.71L5 9.21v6.7zm8 3.38l6-3.38V9.21l-6 3.37v6.71z"/>',
  leaf: '<path d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9-4.03-9-9-9zm0 16c-3.86 0-7-3.14-7-7s3.14-7 7-7 7 3.14 7 7-3.14 7-7 7zm1-11H11v3H8v2h3v3h2v-3h3v-2h-3V8z"/>'
};
---

<Layout 
  title="Roverati Giardini | Progettazione e Manutenzione Aree Verdi a Ferrara"
  description="Da oltre 50 anni l'architettura del verde a Ferrara. Potature in tree climbing, irrigazione e progettazione 3D."
>
  <section class="hero-section relative min-h-screen flex items-end overflow-hidden bg-green-950">
    <div class="absolute inset-0">
      {resolvedHeroImage ? (
        <Image 
          src={resolvedHeroImage} 
          alt="Giardino curato da Roverati Giardini" 
          class="absolute inset-0 w-full h-full object-cover object-center hero-img" 
          loading="eager" 
          widths={[800, 1200, 1920]} 
          sizes="100vw" 
        />
      ) : (
        <div class="absolute inset-0 bg-green-900 w-full h-full"></div>
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-green-950 via-green-950/40 to-green-900/20"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-green-950/70 via-transparent to-transparent"></div>
    </div>

    <div class="absolute top-32 right-8 md:right-16 z-10 hidden md:block">
      <div class="hero-badge relative w-28 h-28 flex items-center justify-center">
        <svg viewBox="0 0 120 120" class="w-full h-full animate-[spin_18s_linear_infinite] absolute inset-0" fill="none">
          <path id="textCircle" d="M 60,60 m -45,0 a 45,45 0 1,1 90,0 a 45,45 0 1,1 -90,0" fill="none"/>
          <text font-size="11" fill="rgba(255,255,255,0.6)" font-family="DM Sans, sans-serif" font-weight="500" letter-spacing="3.5">
            <textPath href="#textCircle">DAL 1974 · FERRARA · VERDE ·&nbsp;</textPath>
          </text>
        </svg>
        <svg viewBox="0 0 36 36" width="36" height="36" fill="none" class="relative z-10">
          <path d="M18 3C18 3 5 10 5 20C5 27.18 10.82 33 18 33C25.18 33 31 27.18 31 20C31 10 18 3 18 3Z" fill="#0C8E36"/>
          <path d="M18 11 L18 30" stroke="white" stroke-width="1.6" stroke-linecap="round"/>
          <path d="M18 19 Q14 15 10 17" stroke="white" stroke-width="1.2" stroke-linecap="round"/>
          <path d="M18 24 Q22 20 26 21" stroke="white" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
      </div>
    </div>

    <div class="relative w-full max-w-7xl mx-auto px-6 pb-20 md:pb-28 z-10">
      <div class="hero-eyebrow inline-flex items-center gap-2.5 mb-8 px-4 py-2 bg-white/8 border border-white/15 backdrop-blur-md text-white/80 text-[10px] font-bold tracking-[0.28em] uppercase rounded-full">
        <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse flex-shrink-0"></span>
        Ferrara e Provincia — Dal 1974
      </div>
      <h1 class="hero-headline font-display text-[clamp(3.5rem,10vw,8.5rem)] text-white leading-[0.88] tracking-[-0.02em] mb-10">
        <span class="block hero-line-1">Il tuo giardino,</span>
        <span class="block hero-line-2">
          <em class="text-green-400 not-italic">la nostra</em>
        </span>
        <span class="block hero-line-3 font-light">opera d'arte.</span>
      </h1>
      <div class="hero-bottom flex flex-col md:flex-row md:items-end gap-10 md:gap-0 md:justify-between">
        <div class="max-w-sm">
          <p class="text-white/55 text-base leading-relaxed mb-8 font-light">
            Dalla progettazione 3D alle potature in tree climbing: 50 anni di eccellenza nel verde.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/contatti" class="cta-primary group inline-flex items-center gap-3 bg-green-500 hover:bg-green-400 text-white px-8 py-4 rounded-full font-semibold text-sm tracking-wide uppercase transition-all duration-300 hover:shadow-2xl hover:shadow-green-500/50 hover:-translate-y-0.5">
              Preventivo Gratuito
              <span class="w-5 h-5 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0 group-hover:bg-white/30 transition-colors">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </span>
            </a>
            <a href="/servizi" class="inline-flex items-center gap-2 bg-white/8 border border-white/20 hover:bg-white/15 text-white/80 hover:text-white px-7 py-4 rounded-full font-medium text-sm transition-all duration-300 backdrop-blur-sm">
              Scopri i Servizi
            </a>
          </div>
        </div>
        <div class="flex gap-8 md:gap-12">
          {[
            { value: '50+', label: 'Anni' },
            { value: '1.200+', label: 'Progetti' },
            { value: '98%', label: 'Soddisfatti' },
          ].map(s => (
            <div class="flex flex-col items-center text-center">
              <span class="font-display text-3xl md:text-4xl text-white font-light tracking-tight">{s.value}</span>
              <span class="text-[10px] text-white/40 mt-1 tracking-widest uppercase font-medium">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="absolute bottom-28 left-1/2 -translate-x-1/2 z-10 hidden md:flex flex-col items-center gap-2">
      <div class="w-5 h-8 rounded-full border border-white/25 flex items-start justify-center pt-1.5">
        <div class="w-0.5 h-1.5 bg-white/50 rounded-full animate-[scrollPulse_1.8s_ease-in-out_infinite]"></div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 z-20 bg-green-500/90 backdrop-blur-sm py-3.5 overflow-hidden select-none border-t border-green-400/30 hero-marquee">
      <div class="marquee-track flex whitespace-nowrap">
        {Array(3).fill(null).map(() => (
          <div class="flex items-center gap-0 flex-shrink-0">
            {[
              'Architettura del Verde',
              'Tree Climbing',
              'Progettazione 3D',
              'Manutenzione Professionale',
              'Impianti di Irrigazione',
              'ISO 9001 Certificata',
              'Dal 1974',
              'Ferrara e Provincia',
            ].map(item => (
              <span class="inline-flex items-center gap-4 px-8 text-sm font-semibold tracking-wide text-white/90 uppercase">
                <span class="w-1 h-1 rounded-full bg-white/50 flex-shrink-0"></span>
                {item}
              </span>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-28 px-6 bg-cloud">
    <div class="max-w-7xl mx-auto">
      <div class="reveal flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
        <div>
          <div class="flex items-center gap-3 mb-5">
            <span class="w-8 h-px bg-green-500"></span>
            <span class="text-[10px] font-bold tracking-[0.3em] uppercase text-green-500">I nostri servizi</span>
          </div>
          <h2 class="font-display text-5xl md:text-6xl text-green-900 leading-[0.92]">
            Ogni verde<br/>
            <em class="font-light text-green-500">ha la sua storia.</em>
          </h2>
        </div>
        <a href="/servizi" class="group inline-flex items-center gap-2 text-sm font-semibold text-green-700 hover:text-green-500 transition-colors self-start md:self-auto">
          Vedi tutti i servizi
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-5">
        
        {serviziEvidenza[0] && (
          <a href={`/servizi/${serviziEvidenza[0].id}`}
             class="reveal service-card group md:col-span-5 relative bg-green-800 rounded-3xl overflow-hidden p-10 min-h-[340px] flex flex-col justify-between hover:-translate-y-2 hover:shadow-2xl hover:shadow-green-900/30 transition-all duration-500">
            <div class="absolute -bottom-20 -right-20 w-64 h-64 rounded-full bg-green-500/20 blur-3xl pointer-events-none"></div>
            <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-green-400/0 via-green-400 to-green-400/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <span class="absolute top-8 right-8 font-display text-[6rem] font-light text-white/[0.06] leading-none select-none">01</span>
            
            <div class="relative z-10">
              <div class="w-14 h-14 rounded-2xl bg-green-500/20 border border-green-400/20 group-hover:bg-green-500 text-green-300 group-hover:text-white flex items-center justify-center mb-10 transition-all duration-300 group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-green-500/30">
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor" set:html={iconeSVG[serviziEvidenza[0].data.icona || 'leaf']} />
              </div>
              <h3 class="text-2xl font-semibold text-white mb-3">{serviziEvidenza[0].data.titolo}</h3>
              <p class="text-sm text-white/50 leading-relaxed max-w-xs font-light">{serviziEvidenza[0].data.descrizioneBreve}</p>
            </div>
            <div class="relative z-10 flex items-center justify-between mt-10">
              <span class="text-xs font-bold text-green-400 tracking-widest uppercase">Scopri</span>
              <div class="w-9 h-9 rounded-full border border-green-500/40 group-hover:bg-green-500 group-hover:border-green-500 flex items-center justify-center transition-all duration-300">
                <svg class="w-4 h-4 text-green-400 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </div>
            </div>
          </a>
        )}

        <div class="md:col-span-7 flex flex-col gap-5">
          {serviziEvidenza.slice(1, 3).map((servizio: CollectionEntry<'servizi'>) => (
            <a href={`/servizi/${servizio.id}`}
               class="reveal service-card group relative bg-white rounded-3xl overflow-hidden border border-green-100 p-10 flex gap-8 items-center hover:-translate-y-1 hover:border-green-300 hover:shadow-xl hover:shadow-green-900/8 transition-all duration-500">
              <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-green-500 to-green-400 scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
              
              <div class="w-16 h-16 rounded-2xl bg-green-50 border border-green-200 text-green-600 group-hover:bg-green-500 group-hover:text-white group-hover:border-green-500 flex items-center justify-center flex-shrink-0 group-hover:scale-105 group-hover:shadow-lg group-hover:shadow-green-500/30 transition-all duration-300">
                <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor" set:html={iconeSVG[servizio.data.icona || 'leaf']} />
              </div>
              
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <h3 class="text-xl font-semibold text-green-900 mb-1.5">{servizio.data.titolo}</h3>
                    <p class="text-sm text-green-700/60 leading-relaxed font-light">{servizio.data.descrizioneBreve}</p>
                  </div>
                  <div class="w-9 h-9 rounded-full border border-green-100 group-hover:bg-green-500 group-hover:border-green-500 flex items-center justify-center transition-all duration-300 flex-shrink-0">
                    <svg class="w-4 h-4 text-green-400 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                  </div>
                </div>
                {servizio.data.tags && servizio.data.tags.length > 0 && (
                  <div class="mt-4 flex gap-2">
                    {servizio.data.tags.map((tag: string) => (
                      <span class="text-[10px] bg-green-50 text-green-600 font-bold tracking-wide uppercase px-3 py-1 rounded-full border border-green-100">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-28 px-6 bg-green-950 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-40 -left-40 w-[500px] h-[500px] rounded-full bg-green-800/30 blur-3xl"></div>
      <div class="absolute -bottom-40 right-0 w-[400px] h-[400px] rounded-full bg-green-600/15 blur-3xl"></div>
    </div>
    <div class="max-w-7xl mx-auto relative">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div class="reveal">
          <div class="flex items-center gap-3 mb-7">
            <span class="w-8 h-px bg-green-500"></span>
            <span class="text-[10px] font-bold tracking-[0.3em] uppercase text-green-500">I nostri lavori</span>
          </div>
          <h2 class="font-display text-5xl md:text-6xl text-white mb-7 leading-[0.92]">
            Un prima<br/>
            e un dopo<br/>
            <em class="text-green-400 font-light">che parlano da soli.</em>
          </h2>
          <p class="text-white/50 leading-relaxed mb-10 text-base font-light max-w-sm">
            Dimostriamo la nostra esperienza con i fatti. Trascina la barra per vedere ogni trasformazione.
          </p>
          <ul class="flex flex-col gap-4 mb-12">
            {[
              'Interventi su misura per ogni tipologia di spazio',
              'Utilizzo di specie autoctone e sostenibili',
              'Garanzia scritta su tutti i lavori eseguiti',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm text-white/60 font-light">
                <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-green-500/20 border border-green-500/40 text-green-400 flex items-center justify-center">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
          <a href="/galleria" class="inline-flex items-center gap-3 group">
            <div class="w-10 h-10 rounded-full bg-green-500 group-hover:bg-green-400 flex items-center justify-center flex-shrink-0 transition-all duration-300 shadow-lg shadow-green-500/30">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
            <span class="text-sm font-semibold text-white/70 group-hover:text-white transition-colors tracking-wide">
              Esplora la Galleria
            </span>
          </a>
        </div>
        
        <div class="reveal">
          {slideHome && slideHome.data.immaginePrima && slideHome.data.immagineDopo ? (
             <BeforeAfterSlider 
               beforeImg={slideHome.data.immaginePrima}
               afterImg={slideHome.data.immagineDopo}
               altText={typeof slideHome.data.titolo === 'string' ? slideHome.data.titolo : slideHome.data.titolo.slug}
             />
          ) : (
             <div class="text-white/50 text-sm border border-white/10 rounded-3xl p-8 text-center bg-white/5">Nessuna trasformazione disponibile. Aggiungila da Keystatic e carica le immagini.</div>
          )}
        </div>
      </div>
    </div>
  </section>

  <section class="py-0 px-6 bg-cloud">
    <div class="max-w-7xl mx-auto">
      <div class="reveal grid grid-cols-2 md:grid-cols-4 border border-green-100 rounded-3xl overflow-hidden">
        {[
          { value: '50+', label: 'Anni di Esperienza' },
          { value: '1.200+', label: 'Progetti Realizzati' },
          { value: '98%', label: 'Clienti Soddisfatti' },
          { value: 'ISO 9001', label: 'Qualità Certificata' },
        ].map((stat, i) => (
          <div class={`stat-item flex flex-col items-center text-center px-6 py-12 relative ${i < 3 ? 'border-r border-green-100' : ''} ${i >= 2 ? 'border-t border-green-100 md:border-t-0' : ''} group hover:bg-green-500 transition-colors duration-300`}>
            <span class="font-display text-4xl md:text-5xl text-green-900 group-hover:text-white tracking-tight font-light mb-1 transition-colors duration-300">{stat.value}</span>
            <span class="text-[11px] font-medium text-green-500 group-hover:text-green-100 mt-1 tracking-wide uppercase transition-colors duration-300">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-6 bg-green-800">
    <div class="max-w-7xl mx-auto">
      <div class="reveal flex flex-col md:flex-row md:items-center gap-10 md:gap-20">
        <div class="flex-shrink-0">
          <div class="flex items-center gap-3 mb-2">
            <span class="w-6 h-px bg-green-400"></span>
            <span class="text-[10px] font-bold tracking-[0.28em] uppercase text-green-400">Si fidano di noi</span>
          </div>
          <p class="text-white/35 text-xs font-light">Enti pubblici e privati</p>
        </div>
        <div class="hidden md:block w-px h-12 bg-white/10 flex-shrink-0"></div>
        <div class="flex flex-wrap items-center gap-x-12 gap-y-5">
          {[
            { name: 'Abbazia di Pomposa', short: 'AP' },
            { name: 'Ospedale di Cona', short: 'OC' },
            { name: 'Rio Latino', short: 'RL' },
          ].map(client => (
            <div class="group flex items-center gap-3 cursor-default">
              <div class="w-9 h-9 rounded-xl bg-white/8 border border-white/10 group-hover:bg-green-500/20 group-hover:border-green-400/30 flex items-center justify-center transition-all duration-300 flex-shrink-0">
                <span class="text-[9px] font-bold text-white/40 group-hover:text-green-300 transition-colors">{client.short}</span>
              </div>
              <span class="text-white/40 group-hover:text-white/75 transition-colors font-medium text-sm tracking-wide">{client.name}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="relative py-36 px-6 bg-cloud overflow-hidden">
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <svg viewBox="0 0 800 800" class="absolute w-[70vw] max-w-3xl opacity-[0.04]" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M400 50C400 50 60 200 60 430C60 620 215 760 400 760C585 760 740 620 740 430C740 200 400 50 400 50Z" fill="#0C8E36"/>
        <path d="M400 120 L400 720" stroke="#0C8E36" stroke-width="6" stroke-linecap="round"/>
        <path d="M400 380 Q290 280 180 320" stroke="#0C8E36" stroke-width="5" stroke-linecap="round"/>
        <path d="M400 480 Q510 380 620 420" stroke="#0C8E36" stroke-width="5" stroke-linecap="round"/>
        <path d="M400 280 Q480 200 560 230" stroke="#0C8E36" stroke-width="4" stroke-linecap="round" opacity="0.6"/>
      </svg>
    </div>
    <div class="reveal relative max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2.5 mb-8 px-5 py-2.5 rounded-full border border-green-200 bg-green-50">
        <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
        <span class="text-[10px] font-bold tracking-[0.28em] uppercase text-green-600">Inizia Oggi</span>
      </div>
      <h2 class="font-display text-5xl md:text-7xl text-green-900 mb-6 leading-[0.92]">
        Trasformiamo il tuo<br/>
        <em class="text-green-500 font-light">spazio verde insieme.</em>
      </h2>
      <p class="text-lg text-green-700/60 mb-12 max-w-xl mx-auto leading-relaxed font-light">
        Sopralluogo gratuito, preventivo in 48 ore. Raccontaci il tuo progetto e lo realizziamo.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/contatti" class="group inline-flex items-center gap-3 bg-green-500 hover:bg-green-600 text-white px-10 py-5 rounded-full font-semibold text-sm tracking-wide uppercase transition-all duration-300 hover:shadow-2xl hover:shadow-green-500/40 hover:-translate-y-1">
          Richiedi Preventivo Gratuito
          <span class="w-5 h-5 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0 group-hover:bg-white/30 transition-colors">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </span>
        </a>
