---
---
<header id="site-header" class="w-full px-6 py-5 sticky top-0 z-50 transition-all duration-500">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    
    <a href="/" class="flex items-center gap-3 group" aria-label="Roverati Giardini - Home">
      <div class="logo-icon w-9 h-9 relative flex-shrink-0">
        <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
          <path d="M18 3C18 3 5 10 5 20C5 27.18 10.82 33 18 33C25.18 33 31 27.18 31 20C31 10 18 3 18 3Z" 
                fill="#0C8E36" class="group-hover:opacity-80 transition-opacity duration-300"/>
          <path d="M18 11 L18 30" stroke="white" stroke-width="1.6" stroke-linecap="round"/>
          <path d="M18 19 Q14 15 10 17" stroke="white" stroke-width="1.2" stroke-linecap="round" opacity="0.9"/>
          <path d="M18 24 Q22 20 26 21" stroke="white" stroke-width="1.2" stroke-linecap="round" opacity="0.9"/>
          <path d="M18 15 Q21 12 24 13" stroke="white" stroke-width="1.0" stroke-linecap="round" opacity="0.6"/>
        </svg>
      </div>
      <div class="flex flex-col leading-none">
        <span class="logo-name text-[17px] font-bold tracking-[0.12em] uppercase text-green-800">Roverati</span>
        <span class="logo-sub text-[9px] tracking-[0.3em] uppercase text-green-500 font-medium mt-0.5">Giardini</span>
      </div>
    </a>
    
    <nav class="hidden md:flex items-center gap-1">
      {[
        { href: '/servizi', label: 'Servizi' },
        { href: '/galleria', label: 'Galleria' },
        { href: '/azienda', label: 'Azienda' },
      ].map(link => (
        <a href={link.href} class="nav-link relative px-4 py-2 text-sm font-medium tracking-wide text-green-800 hover:text-green-500 transition-colors duration-200 group">
          {link.label}
          <span class="absolute bottom-0 left-4 right-4 h-px bg-green-500 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left rounded-full"></span>
        </a>
      ))}
      <a href="/contatti" class="cta-btn ml-4 px-7 py-2.5 bg-green-500 text-white text-sm font-semibold tracking-wider uppercase rounded-full hover:bg-green-600 transition-all duration-300 hover:shadow-lg hover:shadow-green-500/40 hover:-translate-y-0.5">
        Preventivo
      </a>
    </nav>

    <button id="menu-toggle" class="md:hidden flex flex-col gap-[5px] p-2 group" aria-label="Apri menu" aria-expanded="false">
      <span class="ham-line w-6 h-[1.5px] bg-green-800 block transition-all duration-300"></span>
      <span class="ham-line w-4 h-[1.5px] bg-green-800 block transition-all duration-300"></span>
      <span class="ham-line w-6 h-[1.5px] bg-green-800 block transition-all duration-300"></span>
    </button>
  </div>

  <div id="mobile-menu" class="md:hidden overflow-hidden max-h-0 transition-all duration-500 ease-in-out">
    <nav class="pt-4 pb-6 flex flex-col gap-1 border-t border-green-100 mt-4">
      {[
        { href: '/servizi', label: 'Servizi' },
        { href: '/galleria', label: 'Galleria' },
        { href: '/azienda', label: 'Azienda' },
      ].map(link => (
        <a href={link.href} class="px-4 py-3 text-green-800 font-medium hover:text-green-500 hover:bg-green-50 rounded-xl transition-colors text-lg">
          {link.label}
        </a>
      ))}
      <a href="/contatti" class="mt-3 mx-4 py-3 bg-green-500 text-white text-center font-semibold rounded-full hover:bg-green-600 transition-colors">
        Richiedi Preventivo
      </a>
    </nav>
  </div>
</header>

<style>
  #site-header {
    background: transparent;
  }
  
  /* Uso di color-mix per applicare opacità a una variabile nativa mantenendo la coerenza del tema */
  #site-header.scrolled {
    background: color-mix(in srgb, var(--color-cloud) 94%, transparent);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 1px 0 rgba(12, 142, 54, 0.08), 0 4px 24px rgba(0,0,0,0.05);
    padding-top: 0.875rem;
    padding-bottom: 0.875rem;
  }

  /* Hamburger open state */
  #menu-toggle[aria-expanded="true"] .ham-line:nth-child(1) {
    transform: rotate(45deg) translate(4.5px, 4.5px);
  }
  #menu-toggle[aria-expanded="true"] .ham-line:nth-child(2) {
    opacity: 0;
  }
  #menu-toggle[aria-expanded="true"] .ham-line:nth-child(3) {
    transform: rotate(-45deg) translate(4.5px, -4.5px);
  }
</style>
<script>
  let scrollHandler: () => void;

  function initHeader() {
    const header = document.getElementById('site-header');
    const toggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');

    if (!header || !toggle || !mobileMenu) return;

    // Pulisce l'eventuale listener precedente
    if (scrollHandler) {
      window.removeEventListener('scroll', scrollHandler);
    }

    scrollHandler = () => {
      if (window.scrollY > 20) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    };

    window.addEventListener('scroll', scrollHandler, { passive: true });
    scrollHandler(); // Controlla lo stato al primo caricamento

    // Gestione menu mobile
    toggle.onclick = () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      if (isOpen) {
        mobileMenu.style.maxHeight = '0px';
        toggle.setAttribute('aria-expanded', 'false');
      } else {
        mobileMenu.style.maxHeight = mobileMenu.scrollHeight + 'px';
        toggle.setAttribute('aria-expanded', 'true');
      }
    };
  }

  // Hook nativo di Astro per rieseguire lo script ad ogni cambio pagina
  document.addEventListener('astro:page-load', initHeader);
</script>
