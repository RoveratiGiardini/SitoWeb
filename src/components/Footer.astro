---
const currentYear = new Date().getFullYear();
import { Image } from 'astro:assets';
import isoLogo from '../assets/iso-9001-logo.png';
---

<footer class="relative bg-green-950 text-white overflow-hidden">

  <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-green-500 to-transparent"></div>

  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute -bottom-40 -left-40 w-[600px] h-[600px] rounded-full bg-green-800/20 blur-3xl"></div>
    <div class="absolute -top-20 right-0 w-[400px] h-[400px] rounded-full bg-green-600/10 blur-3xl"></div>
  </div>

  <div class="absolute bottom-0 right-0 font-display text-[18vw] italic font-light text-white/[0.025] leading-none select-none pointer-events-none tracking-tighter translate-x-8 translate-y-6">
    verde
  </div>

  <div class="relative max-w-7xl mx-auto px-6 pt-20 pb-10">

    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 pb-16 border-b border-white/10">

      <div class="md:col-span-5">
        <a href="/" class="inline-flex items-center gap-3 mb-8 group" aria-label="Home - Roverati Giardini">
          <div class="w-10 h-10 flex-shrink-0">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full" aria-hidden="true">
              <path d="M18 3C18 3 5 10 5 20C5 27.18 10.82 33 18 33C25.18 33 31 27.18 31 20C31 10 18 3 18 3Z" fill="#0C8E36" class="group-hover:opacity-80 transition-opacity duration-300"/>
              <path d="M18 11 L18 30" stroke="white" stroke-width="1.6" stroke-linecap="round"/>
              <path d="M18 19 Q14 15 10 17" stroke="white" stroke-width="1.2" stroke-linecap="round" opacity="0.9"/>
              <path d="M18 24 Q22 20 26 21" stroke="white" stroke-width="1.2" stroke-linecap="round" opacity="0.9"/>
            </svg>
          </div>
          <div class="flex flex-col leading-none">
            <span class="text-xl font-bold tracking-[0.12em] uppercase text-white">Roverati</span>
            <span class="text-[9px] tracking-[0.3em] uppercase text-green-400 font-medium mt-0.5">Giardini</span>
          </div>
        </a>

        <p class="text-white/55 leading-relaxed mb-10 text-sm max-w-xs font-light">
          Da oltre 50 anni trasformiamo spazi verdi in esperienze straordinarie. Architettura del verde, tree climbing e manutenzione professionale.
        </p>

        <div class="flex flex-col gap-4">
          <a href="https://maps.google.com/?q=Stradello+Ca'+Nova+91,+Dogato+44020+(FE)" target="_blank" rel="noopener noreferrer"
             class="flex items-start gap-3 text-white/55 hover:text-green-400 transition-colors text-sm group" aria-label="Apri posizione su Google Maps">
            <span class="mt-0.5 flex-shrink-0 w-6 h-6 rounded-lg bg-green-500/20 group-hover:bg-green-500/30 flex items-center justify-center transition-colors">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
              </svg>
            </span>
            Stradello Ca' Nova 91, Dogato 44020 (FE)
          </a>
          
          <a href="tel:+393882425127"
             class="flex items-center gap-3 text-white/55 hover:text-green-400 transition-colors text-sm group" aria-label="Chiama il numero principale">
            <span class="flex-shrink-0 w-6 h-6 rounded-lg bg-green-500/20 group-hover:bg-green-500/30 flex items-center justify-center transition-colors">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
              </svg>
            </span>
            +39 388 242 5127
          </a>
          
          <a href="mailto:info@roveratigiardini.com"
             class="flex items-center gap-3 text-white/55 hover:text-green-400 transition-colors text-sm group" aria-label="Invia un'email">
            <span class="flex-shrink-0 w-6 h-6 rounded-lg bg-green-500/20 group-hover:bg-green-500/30 flex items-center justify-center transition-colors">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
              </svg>
            </span>
            info@roveratigiardini.com
          </a>
        </div>
      </div>

      <div class="md:col-span-1 hidden md:block"></div>

      <div class="md:col-span-3">
        <h4 class="text-[10px] font-bold tracking-[0.25em] uppercase text-green-400 mb-6">Esplora</h4>
        <ul class="flex flex-col gap-3.5">
          {[
            { href: '/servizi', label: 'I Nostri Servizi' },
            { href: '/galleria', label: 'Portfolio Lavori' },
            { href: '/azienda', label: 'Chi Siamo' },
            { href: '/contatti', label: 'Contattaci' },
            { href: '/contatti', label: 'Richiedi Preventivo' },
          ].map(link => (
            <li>
              <a href={link.href} class="text-white/55 hover:text-white transition-colors text-sm inline-flex items-center gap-2.5 group">
                <span class="w-3 h-px bg-green-500/50 group-hover:w-5 group-hover:bg-green-400 transition-all duration-300 rounded-full"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-3">
        <h4 class="text-[10px] font-bold tracking-[0.25em] uppercase text-green-400 mb-6">Certificazioni</h4>
        <p class="text-white/55 text-sm mb-6 leading-relaxed">
          Azienda certificata ISO 9001:2015 per la qualità dei servizi nel settore del verde.
        </p>
        <div class="inline-flex items-center gap-4 bg-white/5 border border-white/10 rounded-2xl px-4 py-3 hover:bg-green-500/10 hover:border-green-500/30 transition-all duration-300 cursor-default">
          <div class="w-15 h-15 flex-shrink-0 flex items-center justify-center">
            <Image 
              src={isoLogo} 
              alt="Certificazione ISO 9001:2015" 
              class="w-full h-full object-contain overflow-hidden rounded-full"
            />
          </div>
          
          <div>
            <div class="text-white text-sm font-semibold">ISO 9001:2015</div>
            <div class="text-white/40 text-xs mt-0.5">Qualità Certificata</div>
          </div>
        </div>

        <a href="/contatti" class="mt-8 flex items-center gap-3 group" aria-label="Richiedi un preventivo gratuito">
          <div class="w-10 h-10 rounded-full bg-green-500 group-hover:bg-green-400 flex items-center justify-center transition-colors duration-300 flex-shrink-0 shadow-lg shadow-green-500/30">
            <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </div>
          <span class="text-sm font-medium text-white/70 group-hover:text-white transition-colors">Preventivo gratuito</span>
        </a>
      </div>
    </div>

    <div class="pt-8 flex flex-col md:flex-row justify-between items-center gap-6 md:gap-4 text-xs text-white/35">
      <p>© {currentYear} Roverati Giardini S.r.l. — Tutti i diritti riservati</p>
      
      <p class="text-center">
        Design & Sviluppo web: 
        <a href="https://www.linkedin.com/in/nicolas-maule" target="_blank" rel="noopener noreferrer nofollow" class="text-white/50 hover:text-white transition-colors font-medium">
          Nicolas Maule
        </a>
      </p>

      <div class="flex gap-6">
        <a href="/privacy-policy" class="hover:text-white transition-colors">Privacy Policy</a>
      </div>
    </div>

  </div>
</footer>
